# Backend API key
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend: Leave empty in dev (Vite proxies /api/ → localhost:3000)
# Set to your deployed backend URL for production builds / Capacitor APK
# Example: VITE_API_URL=https://api.healu.yourdomain.com
VITE_API_URL=

# Capacitor: URL the in-app browser loads during development
# Android emulator → 10.0.2.2:3000 (maps to host localhost)
# Real device on LAN → your LAN IP, e.g. http://192.168.1.5:3000
CAPACITOR_DEV_URL=http://10.0.2.2:3000
